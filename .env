# ==========================================
# 1. APPLICATION CORE
# ==========================================
PORT=5000
NODE_ENV=development
# URL Frontend (Next.js) untuk kebutuhan Whitelist CORS
CLIENT_URL=http://localhost:3000 

# ==========================================
# 2. DATABASE CONFIGURATION (POSTGRESQL)
# ==========================================
DB_USERNAME=postgres
DB_PASSWORD=123
DB_NAME=analog_id
DB_HOST=127.0.0.1
DB_DIALECT=postgres

# ==========================================
# 3. AUTHENTICATION & SECURITY (JWT)
# ==========================================
JWT_SECRET=rahasia_banget_123
# Standarisasi masa berlaku token (1 hari)
JWT_EXPIRES_IN=1d

# ==========================================
# 4. INTERNAL MICROSERVICE COMMUNICATION
# ==========================================
# Kunci rahasia untuk komunikasi antara Node.js dan FastAPI Worker
# Wajib sama persis dengan yang nanti disetting di Python FastAPI
INTERNAL_API_KEY=analog_worker_secret_key_2026!